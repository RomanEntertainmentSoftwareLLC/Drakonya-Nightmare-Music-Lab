# Secrets / local env
.env
*.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Local state / logs / generated outputs
state/*
!state/.gitkeep
logs/*
!logs/.gitkeep

# Generated media assets
data/inbox/suno_downloads/*
!data/inbox/
!data/inbox/.gitkeep
!data/inbox/suno_downloads/
!data/inbox/suno_downloads/.gitkeep
data/tracks/*
data/covers/*
data/videos/*
data/releases/*
data/analytics/*
data/slop_bin/*

!data/tracks/.gitkeep
!data/covers/.gitkeep
!data/videos/.gitkeep
!data/releases/.gitkeep
!data/analytics/.gitkeep
!data/slop_bin/.gitkeep

# Runtime job records
data/jobs/*.json
data/jobs/*
!data/jobs/.gitkeep
