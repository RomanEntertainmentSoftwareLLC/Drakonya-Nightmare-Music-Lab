# Drakonya Nightmare AI Music Lab
DRAKONYA_ROOT=/opt/drakonya-nightmare-music-lab

# Runtime mode
DRAKONYA_ENV=local

# Storage
DRAKONYA_DB=state/drakonya.sqlite3
DRAKONYA_LOG_DIR=logs

# External tool placeholders
SUNO_ENABLED=false
DISTROKID_ENABLED=false
YOUTUBE_ENABLED=false
VEO_ENABLED=false
SEEDANCE_ENABLED=false

# Hermes / agent layer placeholders
HERMES_ENABLED=true
HERMES_PROJECT=drakonya-nightmare-music-lab

# Suno provider selection
SUNO_PROVIDER=manual
SUNO_PRIVATE_ENABLED=false
SUNO_MAX_BATCH_GENERATIONS=20
SUNO_MAX_DAILY_GENERATIONS=60
SUNO_DOWNLOAD_DIR=data/tracks/inbox

# Suno sidecar connection
SUNO_SIDECAR_URL=http://127.0.0.1:8766
